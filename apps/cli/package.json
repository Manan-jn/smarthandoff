{
  "name": "@smarthandoff/cli",
  "version": "0.1.0",
  "description": "Smart Handoff CLI — smarthandoff command",
  "type": "module",
  "bin": {
    "smarthandoff": "./dist/index.js",
    "shoff": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean",
    "dev": "tsup src/index.ts --format esm --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@smarthandoff/core": "workspace:*",
    "commander": "^12.0.0",
    "clipboardy": "^4.0.0",
    "js-yaml": "^4.1.0",
    "ora": "^8.0.0",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "vitest": "^1.6.0",
    "typescript": "^5.4.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0"
  }
}
