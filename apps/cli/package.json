{
  "name": "@smarthandoff/cli",
  "version": "0.2.0",
  "description": "Smart Handoff CLI — zero-friction AI session continuity across Claude, Gemini, Codex, Cursor",
  "type": "module",
  "bin": {
    "smarthandoff": "./dist/index.js",
    "shoff": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean",
    "dev": "tsup src/index.ts --format esm --watch",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@smarthandoff/core": "workspace:*",
    "commander": "^12.0.0",
    "clipboardy": "^4.0.0",
    "js-yaml": "^4.1.0",
    "ora": "^8.0.0",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "vitest": "^1.6.0",
    "typescript": "^5.4.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0"
  },
  "keywords": [
    "ai",
    "claude",
    "gemini",
    "codex",
    "cursor",
    "handoff",
    "session",
    "continuity",
    "rate-limit",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Manan-jn/smarthandoff.git"
  },
  "homepage": "https://github.com/Manan-jn/smarthandoff#readme",
  "bugs": {
    "url": "https://github.com/Manan-jn/smarthandoff/issues"
  }
}
